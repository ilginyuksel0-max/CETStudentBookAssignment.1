@model IEnumerable<CetStudentBook.Models.CartItem>

@{
    ViewData["Title"] = "Cart";
}

<h2>Shopping Cart</h2>

@if (!Model.Any())
{
    <p>Your cart is empty.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Price</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Book?.Name</td>
                <td>@item.Quantity</td>
                <td>@((item.Book?.PageCount ?? 0) * item.Quantity) TL</td>
            </tr>
        }
        </tbody>
    </table>

    <a asp-controller="Cart" asp-action="BuyCart" class="btn btn-success">Buy Cart</a>
}