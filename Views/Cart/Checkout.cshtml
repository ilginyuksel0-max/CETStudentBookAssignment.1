@model CetStudentBook.Models.CheckoutViewModel

<div class="container mt-4">
    <h2>Checkout</h2>
    <p>Please enter your delivery address.</p>

    <form asp-action="Checkout" method="post">
        <input type="hidden" asp-for="BookId" />

        <div class="mb-3">
            <label asp-for="FullName" class="form-label">Full Name</label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="AddressLine" class="form-label">Address</label>
            <textarea asp-for="AddressLine" class="form-control"></textarea>
            <span asp-validation-for="AddressLine" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="City" class="form-label">City</label>
            <input asp-for="City" class="form-control" />
            <span asp-validation-for="City" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PostalCode" class="form-label">Postal Code</label>
            <input asp-for="PostalCode" class="form-control" />
        </div>

        <button type="submit" class="btn btn-success">Place Order</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}