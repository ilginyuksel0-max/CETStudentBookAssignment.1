<div class="container mt-4">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top" style="height:250px; object-fit:cover;" alt="@item.Name" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/300x180?text=No+Image" class="card-img-top" style="height:250px; object-fit:cover;" alt="No Image" />
                    }

                    <div class="card-body">
                        <h5>@item.Name</h5>
                        <p>@item.Author</p>
                        <p><strong>@item.PageCount pages</strong></p>

                        <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary w-100 mb-2">
                            View Book
                        </a>

                        <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.Id" class="btn btn-outline-danger w-100 mb-2">
                            Add to Cart
                        </a>

                        <a asp-controller="Cart" asp-action="Buy" asp-route-id="@item.Id" class="btn btn-success w-100">
                            Buy Now
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>