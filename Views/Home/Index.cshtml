@model IEnumerable<CetStudentBook.Models.Book>

<div class="container mt-4">

    <div class="mb-4">
        <h3 style="font-weight:800;">Popüler Kitaplar</h3>
        <p class="text-muted">En çok tercih edilen kitapları keşfet.</p>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-2 col-md-3 col-6 mb-4">
                <div class="product-card">

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="product-img w-100" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/200x260?text=No+Image" class="product-img w-100" />
                    }

                    <div class="product-title mt-2">@item.Name</div>
                    <div class="product-author">@item.Author</div>
                    
                    
                    <div class="discount-badge">%50</div>

                    <!-- GEÇİCİ FİYAT -->
                    <div class="product-price">250,00 TL</div>

                    <a asp-controller="Books"
                       asp-action="Details"
                       asp-route-id="@item.Id"
                       class="add-cart-btn mt-2 text-center d-block">
                        İncele
                    </a>

                </div>
            </div>
        }
    </div>
</div>